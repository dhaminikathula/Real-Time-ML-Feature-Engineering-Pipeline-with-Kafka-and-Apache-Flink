# ============================================================
#  Environment Variables – Real-Time ML Feature Pipeline
#  Copy this file to .env and adjust values as needed.
# ============================================================

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092     # Internal Docker network address
# KAFKA_BOOTSTRAP_SERVERS=localhost:29092  # Use this for host-machine access

# --- Kafka Topics ---
USER_EVENTS_TOPIC=user-events
CONTENT_METADATA_TOPIC=content-metadata
FEATURE_STORE_TOPIC=feature-store

# --- Producer Configuration ---
EVENTS_PER_SECOND=10                   # Real-time event production rate
TIME_ACCELERATION_FACTOR=60            # 1 real second = 60 simulated seconds
                                       # (60× speedup: 1 hr window fires in ~60 real seconds)
LATE_EVENT_PERCENTAGE=0.05             # 5% of events are deliberately late
LATE_EVENT_MIN_DELAY_S=35              # Min simulated-time delay for late events (> watermark tolerance)
LATE_EVENT_MAX_DELAY_S=90              # Max simulated-time delay for late events

# --- Flink ---
# Watermark out-of-orderness tolerance: 30 seconds (hardcoded in feature_engineering.py DDL)
# Checkpoint interval: 60,000 ms (60 seconds)
# Parallelism: 2

# --- Dashboard ---
DASHBOARD_PORT=8080
